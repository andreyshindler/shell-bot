# Copy to a root-owned, 0600 file (e.g. /etc/shell_bot.env) and fill in.
# NEVER commit the real values — this .example file is the only env file in git.

# Token from @BotFather
BOT_TOKEN=

# Your numeric Telegram user id, from @userinfobot
ALLOWED_USER_ID=

# Docker only: UID/GID of the host user that owns the bind-mounted project
# dir (see docker-compose.yml), so the in-container user can write
# shell_bot.log there. Find with `id -u` / `id -g`. Not used by systemd.
HOST_UID=1000
HOST_GID=1000

# --- .env editor Mini App (optional) --------------------------------------
# Set WEBAPP_URL to enable /env, which opens a Telegram Mini App to view/edit
# the .env in the bot's current directory. Must be the HTTPS root that nginx
# serves the app from (Telegram requires HTTPS). Leave blank to disable.
WEBAPP_URL=
# Address the bot's Mini App server binds to. systemd: 127.0.0.1:8081 (nginx
# proxies to it). Docker: set 0.0.0.0:8081 and publish 127.0.0.1:8081:8081 in
# docker-compose.yml so only the host (and its nginx) can reach it.
WEBAPP_BIND=127.0.0.1:8081
